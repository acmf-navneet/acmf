POSTGRES_DB=acmf_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Replace with your EC2 public IP, e.g. http://12.34.56.78
# For local dev use: http://localhost
FRONTEND_URLS=http://<EC2_PUBLIC_IP>

# Host directory for JHipster generation (Docker bind mount). Default matches Ubuntu EC2.
# Local Mac/Linux example: HOST_ROOT_PATH=/Users/you/acmf-generated-projects
HOST_ROOT_PATH=/home/ubuntu/generated-projects
