FROM node:18 as build
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# FIXED: Added ARG and ENV to capture the API URL during build
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]